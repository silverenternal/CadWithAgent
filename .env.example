# CadAgent 环境变量配置
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的真实 API Key
# 3. 运行：source .env 或在运行前 export
#
# ⚠️ 注意：.env 文件包含敏感信息，请勿提交到 Git

# =============================================================================
# ZazaZ API 配置（默认）
# =============================================================================
# ⚠️ 必须设置：你的 ZazaZ API Key
# 获取方式：访问 https://zazaz.top 注册并创建 API Key
PROVIDER_ZAZAZ_API_KEY=your_api_key_here

# ZazaZ API URL（可选，默认：https://zazaz.top/v1）
PROVIDER_ZAZAZ_API_URL=https://zazaz.top/v1

# 模型名称（可选，默认：./Qwen3.5-27B-FP8）
PROVIDER_ZAZAZ_MODEL=./Qwen3.5-27B-FP8

# =============================================================================
# ZazaZ LLM Client (新增)
# =============================================================================
# 使用 ZazaZ 进行 AI 辅助功能：
# - AI 辅助合并设计分支
# - 冲突解决
# - 分支目的推断
# - 任务规划
#
# 使用示例：
# ```rust
# use cadagent::bridge::zaza_client::ZazaClient;
#
# // 从环境变量创建客户端
# let client = ZazaClient::from_env()?;
#
# // 生成响应
# let response = client.generate("Explain CAD constraints").await?;
#
# // AI 辅助合并
# let advice = client.assist_merge("scheme-A", "scheme-B", "Conflict description").await?;
# ```

# =============================================================================
# OpenAI API 配置（可选，如使用 OpenAI 请取消注释并填写）
# =============================================================================
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# =============================================================================
# 其他配置（可选）
# =============================================================================
# 请求超时（毫秒，默认：60000）
# CADAGENT_TIMEOUT_MS=60000

# 最大重试次数（默认：3）
# CADAGENT_MAX_RETRIES=3
