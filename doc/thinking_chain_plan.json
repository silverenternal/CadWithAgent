{
  "name": "cad_geometry_reasoning_chain",
  "description": "CAD图纸的几何推理思维链：分五步逐步从图纸中识别、校验、推导几何信息，输出可解释的完整几何/约束信息",
  "parameters": {
    "type": "object",
    "properties": {
      "drawing_info": {
        "type": "object",
        "properties": {
          "drawing_type": {"type": "string", "enum": ["raster", "vector"], "description": "图纸类型：栅格图（图像）/矢量图"},
          "drawing_data": {"type": "string", "description": "图纸数据：栅格图传base64编码，矢量图传JSON格式的路径数据"},
          "coordinate_range": {"type": "array", "items": {"type": "number"}, "default": [1, 64], "description": "坐标归一化范围"}
        },
        "required": ["drawing_type", "drawing_data"]
      },
      "reasoning_mode": {
        "type": "string",
        "enum": ["step_by_step", "one_click"],
        "default": "one_click",
        "description": "推理模式：分步返回（step_by_step）/一键返回完整结果（one_click）"
      }
    },
    "required": ["drawing_info"]
  },
  "returns": {
    "type": "object",
    "properties": {
      "reasoning_chain": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "step": {"type": "number", "description": "推理步骤（1-5）"},
            "step_name": {"type": "string", "description": "步骤名称"},
            "action": {"type": "string", "description": "该步骤执行的算法动作"},
            "result": {"type": "object", "description": "该步骤的输出结果"},
            "explanation": {"type": "string", "description": "该步骤的推理解释"}
          }
        }
      },
      "final_geometry_info": {
        "type": "object",
        "properties": {
          "primitives": {"type": "array", "description": "最终精准基元列表"},
          "constraints": {"type": "array", "description": "最终合法约束列表"},
          "topology_graph": {"type": "object", "description": "几何拓扑图（节点=基元，边=约束）"}
        }
      }
    }
  }
}
